# Copiá este archivo a ".env" (sin el ".example") y completá con tus datos
# reales de Supabase. El archivo ".env" nunca se sube a GitHub (ver
# .gitignore) — en Vercel estas mismas variables se cargan desde Project
# Settings -> Environment Variables, no desde este archivo.

SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_KEY=tu-service-role-key
